{
  "compilerOptions": {
    // TS 6.x: tsup's dts build injects `baseUrl` (removed from this config) into rollup-plugin-dts,
    // which triggers deprecation error TS5101 without this bridge flag. Remove once tsup stops injecting baseUrl.
    "ignoreDeprecations": "6.0",
    "rootDir": "./src",
    "paths": {
      "#src/*": ["./src/*"]
    },
    "outDir": "./dist",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitAny": true,
    "lib": ["esNext"],
    "target": "esNext",
    "module": "nodeNext",
    "moduleResolution": "nodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["./src"],
  "exclude": ["node_modules"]
}
